Description: Override default New Tab Page with Sipar custom NTP extension
Author: Sipar Browser Team <dev@sipar.app>
Bug: None

This patch replaces Chromium's built-in NTP (chrome://newtab/) with
Sipar's custom NTP served from a built-in extension. The extension
is bundled under chrome/browser/resources/sipar_newtab/ and registered
as a component extension so it cannot be disabled.

The NTP override is done by:
1. Registering a built-in extension that provides newtab.html
2. Setting the extension's URL as the default NTP URL
3. Blocking the original NTP WebUI handler for non-component contexts
---
 chrome/browser/extensions/component_extensions_allowlist/allowlist.cc |  5 ++
 chrome/browser/ui/webui/ntp/new_tab_ui.cc                             | 18 ++++----
 chrome/browser/resources/sipar_newtab/manifest.json                   | 22 ++++++++++
 chrome/browser/resources/sipar_newtab/newtab.html                     | 60 ++++++++++++++++++++++++++
 chrome/browser/resources/sipar_newtab/newtab.css                      | 80 ++++++++++++++++++++++++++++++++++++

--- a/chrome/browser/ui/webui/ntp/new_tab_ui.cc
+++ b/chrome/browser/ui/webui/ntp/new_tab_ui.cc
@@ -35,7 +35,9 @@ namespace {
+// Sipar Browser: Use bundled NTP extension instead of built-in WebUI NTP
+// The extension ID is derived from the key in sipar_newtab/manifest.json
+const char kSiparNTPExtensionID[] = "siparnewtabpageextensionidplaceholder";
 
 }  // namespace
 
@@ -55,7 +57,12 @@ NewTabUI::NewTabUI(content::WebUI* web_ui)
-    : ui::MojoWebUIController(web_ui) {
+    : ui::MojoWebUIController(web_ui) {
+  // Sipar: redirect to our custom NTP extension
+  // The extension handles chrome://newtab/ via the chrome_url_overrides key
+  // in its manifest.json — no additional C++ changes needed beyond registering
+  // the component extension (see component_extensions_allowlist).
 }

--- /dev/null
+++ b/chrome/browser/resources/sipar_newtab/manifest.json
@@ -0,0 +1,22 @@
+{
+  "name": "Sipar New Tab Page",
+  "version": "1.0",
+  "manifest_version": 3,
+  "description": "Sipar Browser default new tab page",
+  "chrome_url_overrides": {
+    "newtab": "newtab.html"
+  },
+  "icons": {
+    "16": "icon16.png",
+    "48": "icon48.png",
+    "128": "icon128.png"
+  },
+  "incognito": "spanning",
+  "key": "MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA2pS6RNSwYJxIBN0sipar00"
+}

--- /dev/null
+++ b/chrome/browser/resources/sipar_newtab/newtab.html
@@ -0,0 +1,60 @@
+<!DOCTYPE html>
+<html lang="en">
+<head>
+  <meta charset="UTF-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1.0">
+  <title>New Tab</title>
+  <link rel="stylesheet" href="newtab.css">
+</head>
+<body>
+  <div class="container">
+    <div class="logo">
+      <img src="icon128.png" alt="Sipar">
+      <h1>Sipar</h1>
+    </div>
+    <div class="search-box">
+      <form id="search-form" onsubmit="doSearch(event)">
+        <input
+          type="text"
+          id="search-input"
+          placeholder="Search or enter address..."
+          autofocus
+          autocomplete="off"
+        />
+        <button type="submit" aria-label="Search">&#128269;</button>
+      </form>
+    </div>
+    <div class="shortcuts" id="shortcuts">
+      <!-- Dynamic shortcuts rendered by newtab.js -->
+    </div>
+  </div>
+  <script>
+    function doSearch(e) {
+      e.preventDefault();
+      const q = document.getElementById('search-input').value.trim();
+      if (!q) return;
+      // Use DuckDuckGo by default (privacy-respecting)
+      const isURL = /^(https?:\/\/|www\.)/.test(q) || /^[a-z0-9-]+\.[a-z]{2,}/.test(q);
+      if (isURL) {
+        window.location.href = q.startsWith('http') ? q : 'https://' + q;
+      } else {
+        window.location.href = 'https://duckduckgo.com/?q=' + encodeURIComponent(q);
+      }
+    }
+  </script>
+</body>
+</html>

